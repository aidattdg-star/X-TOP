# Copie para .env e preencha. No Vercel, defina as MESMAS variáveis em Project Settings -> Environment Variables.
# (As VITE_* são injetadas no build; as sem prefixo são usadas no servidor.)

SUPABASE_PROJECT_ID="seu-project-ref"
SUPABASE_URL="https://seu-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

VITE_SUPABASE_PROJECT_ID="seu-project-ref"
VITE_SUPABASE_URL="https://seu-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Server-side apenas (NUNCA expor no front). Usada pelas automações/worker.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
